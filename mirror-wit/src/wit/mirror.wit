// Mirror WIT Interface Specification (v0.1.0)
//
// This defines the WebAssembly Component Model interface for Mirror modules.
// Modules are sandboxed WebAssembly components that communicate via JSONL streams.
//
// See: https://component-model.bytecodealliance.org/

package mirror:v0.1.0;

// ============================================================================
// Core Types
// ============================================================================

/// Capability token identifying what a module is allowed to do
record permission {
  name: string,
}

/// Response from module initialization
record init-response {
  version: u32,
  tags: list<string>,
}

/// Message response from handle_message
record message-response {
  success: bool,
  data: option<list<u8>>,
  error: option<string>,
}

// ============================================================================
// Main World - Interface between daemon and modules
// ============================================================================

world mirror-runtime {
  // Called once when module loads - returns version and capabilities
  func init() -> result<init-response, string>;

  // Main message handler (bytes in, bytes out)
  // Input is JSONL format, output is also JSONL format
  func handle_message(payload: list<u8>) -> result<message-response, string>;

  // Get current module's permissions
  func get_permissions() -> record<{ id: string, capabilities: list<string> }>;

  // Filesystem operations (abstracted from OS-specifics)
  func fs_read(path: string, offset: u64, len: u32) -> result<list<u8>, string>;
  func fs_write(path: string, data: list<u8>) -> result<bool, string>;
  func fs_exists(path: string) -> bool;
}
```
